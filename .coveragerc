[run]
source = src
branch = True
parallel = True
omit =
    src/__pycache__/*
    src/*/__pycache__/*

[report]
show_missing = True
skip_empty = True
skip_covered = False
precision = 1
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    raise AssertionError

[html]
directory = coverage-html