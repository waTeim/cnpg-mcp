# Makefile for cnpg-mcp MCP Server
# Builds and pushes container images.
#
# CANONICAL CONFIG: mcp-project.yaml at the repo root is the single source of
# truth for ports, image names, registry, helm release, namespace, etc.
# make.env is regenerated automatically when mcp-project.yaml changes.
#
# Helm release values are a deployment artifact at the repo root, named
# after the helm release (default: $(HELM_VALUES_FILE) → $(HELM_RELEASE).yaml).
# That file is NOT generated by sync-config — edit it directly.

# Default target
.PHONY: all
all: build

# Include configuration generated from mcp-project.yaml.
-include make.env

# Default values (each is overridden by make.env once it exists). Keeping
# them here means an unconfigured checkout still does *something* sensible.
REGISTRY ?= your-registry.example.com
IMAGE_NAME ?= cnpg-mcp-server
TEST_IMAGE_NAME ?= cnpg-mcp-test-server
TAG ?= latest
PLATFORM ?= linux/amd64
CONTAINER_TOOL ?= docker
HELM_RELEASE ?= cnpg-mcp
HELM_NAMESPACE ?= default
HELM_CHART_NAME ?= cnpg-mcp
# Mirrors Helm's default fullname template: <release>-<chart> unless the
# release already contains the chart name. sync-config.py also computes this
# and emits a literal value to make.env, but the conditional default keeps
# `make` working before sync-config is run.
HELM_SERVICE ?= $(if $(findstring $(HELM_CHART_NAME),$(HELM_RELEASE)),$(HELM_RELEASE),$(HELM_RELEASE)-$(HELM_CHART_NAME))
# Release-level values overlay (NOT chart/values.yaml — that's chart defaults).
# Lives at repo root as <release>.yaml; treated as a deployment artifact.
HELM_VALUES_FILE ?= $(HELM_RELEASE).yaml
MCP_PORT ?= 4200
MCP_TEST_PORT ?= 4201

# Derived values
IMAGE_FULL := $(REGISTRY)/$(IMAGE_NAME):$(TAG)
TEST_IMAGE_FULL := $(REGISTRY)/$(TEST_IMAGE_NAME):$(TAG)

#
# Configuration targets
#

.PHONY: config
config: ## Regenerate make.env from mcp-project.yaml
	python bin/sync-config.py

make.env: mcp-project.yaml bin/sync-config.py
	@echo "Regenerating make.env from mcp-project.yaml..."
	python bin/sync-config.py

#
# Container build targets
#

.PHONY: build
build: ## Build container image
	@echo "Building container image: $(IMAGE_FULL)"
	$(CONTAINER_TOOL) build --tag $(IMAGE_FULL) --platform $(PLATFORM) --file Dockerfile .
	@echo "✓ Built: $(IMAGE_FULL)"

.PHONY: build-no-cache
build-no-cache:
	@echo "Building container image (no cache): $(IMAGE_FULL)"
	$(CONTAINER_TOOL) build \
		--no-cache \
		--tag $(IMAGE_FULL) \
		--platform $(PLATFORM) \
		--file Dockerfile \
		.
	@echo "✓ Built: $(IMAGE_FULL)"

.PHONY: push
push: ## Push container image to registry
	@echo "Pushing container image: $(IMAGE_FULL)"
	$(CONTAINER_TOOL) push $(IMAGE_FULL)
	@echo "✓ Pushed: $(IMAGE_FULL)"

.PHONY: build-push
build-push: build push ## Build and push container image

#
# Test container build targets
#

.PHONY: build-test
build-test: build ## Build test container image (FROM main image)
	@echo "Building test container image: $(TEST_IMAGE_FULL) (FROM $(IMAGE_FULL))"
	$(CONTAINER_TOOL) build \
		--tag $(TEST_IMAGE_FULL) \
		--platform $(PLATFORM) \
		--build-arg BASE_IMAGE=$(IMAGE_FULL) \
		--file test/Dockerfile \
		.
	@echo "✓ Built: $(TEST_IMAGE_FULL)"

.PHONY: build-test-no-cache
build-test-no-cache: build-no-cache
	@echo "Building test container image (no cache): $(TEST_IMAGE_FULL) (FROM $(IMAGE_FULL))"
	$(CONTAINER_TOOL) build \
		--no-cache \
		--tag $(TEST_IMAGE_FULL) \
		--platform $(PLATFORM) \
		--build-arg BASE_IMAGE=$(IMAGE_FULL) \
		--file test/Dockerfile \
		.
	@echo "✓ Built: $(TEST_IMAGE_FULL)"

.PHONY: push-test
push-test: ## Push test container image to registry
	@echo "Pushing test container image: $(TEST_IMAGE_FULL)"
	$(CONTAINER_TOOL) push $(TEST_IMAGE_FULL)
	@echo "✓ Pushed: $(TEST_IMAGE_FULL)"

.PHONY: build-push-test
build-push-test: build-test push-test ## Build and push test container image

.PHONY: build-all
build-all: build build-test ## Build both production and test container images

.PHONY: push-all
push-all: push push-test ## Push both production and test container images

.PHONY: build-push-all
build-push-all: build-push build-push-test ## Build and push both container images

#
# Helm chart targets
#

.PHONY: helm-lint
helm-lint: ## Lint Helm chart
	@echo "Linting Helm chart..."
	helm lint chart/

.PHONY: helm-template
helm-template: ## Render Helm chart templates with the release values overlay
	@echo "Rendering Helm chart templates..."
	helm template $(HELM_RELEASE) chart/ \
		--namespace $(HELM_NAMESPACE) \
		-f $(HELM_VALUES_FILE)

.PHONY: helm-deps
helm-deps: ## Update Helm chart dependencies
	@echo "Updating Helm chart dependencies..."
	helm dependency update chart/

# NOTE: --create-namespace is intentionally OMITTED. It assumes the
# deploying identity has cluster-admin namespace-create rights. Operators
# without that privilege should create the namespace ahead of time.
# --wait is also OMITTED so a crashing sidecar doesn't block helm and
# leave Kubernetes objects in an ambiguous state. Inspect readiness with
# `make k8s-pods` / `kubectl describe`.
.PHONY: helm-install
helm-install: ## Install (or upgrade) Helm release with the release values overlay
	@echo "Installing Helm chart: $(HELM_RELEASE) (namespace=$(HELM_NAMESPACE), values=$(HELM_VALUES_FILE))"
	helm upgrade --install $(HELM_RELEASE) chart/ \
		--namespace $(HELM_NAMESPACE) \
		-f $(HELM_VALUES_FILE)
	@echo "✓ Installed: $(HELM_RELEASE) in namespace $(HELM_NAMESPACE)"

.PHONY: helm-upgrade
helm-upgrade: ## Upgrade existing Helm release with the release values overlay
	@echo "Upgrading Helm release: $(HELM_RELEASE)"
	helm upgrade $(HELM_RELEASE) chart/ \
		--namespace $(HELM_NAMESPACE) \
		-f $(HELM_VALUES_FILE)
	@echo "✓ Upgraded: $(HELM_RELEASE)"

.PHONY: helm-uninstall
helm-uninstall: ## Uninstall Helm release
	@echo "Uninstalling Helm release: $(HELM_RELEASE)"
	helm uninstall $(HELM_RELEASE) --namespace $(HELM_NAMESPACE)
	@echo "✓ Uninstalled: $(HELM_RELEASE)"

.PHONY: helm-status
helm-status: ## Show Helm release status
	helm status $(HELM_RELEASE) --namespace $(HELM_NAMESPACE)

#
# Development targets
#

.PHONY: dev-run
dev-run: ## Run production server locally on $(MCP_PORT)
	@echo "Starting production server on port $(MCP_PORT)..."
	python src/cnpg_mcp_server.py --port $(MCP_PORT)

.PHONY: dev-run-test
dev-run-test: ## Run test server locally (no auth) on $(MCP_TEST_PORT)
	@echo "Starting test server (no auth) on port $(MCP_TEST_PORT)..."
	python src/cnpg_mcp_test_server.py --no-auth --port $(MCP_TEST_PORT)

.PHONY: test
test: ## Start local test server, run MCP tests, then stop it
	python test/run-local-tests.py --port $(MCP_TEST_PORT)

.PHONY: test-integration
test-integration: check-kube-context ## Run local test server with mutating CloudNativePG integration tests
	python test/run-local-tests.py --port $(MCP_TEST_PORT) --include-integration

.PHONY: check-kube-context
check-kube-context: ## Verify kubectl has a usable current context
	@command -v kubectl >/dev/null 2>&1 || { \
		echo "error: kubectl not found on PATH"; \
		exit 2; \
	}
	@kubectl config current-context >/dev/null 2>&1 || { \
		echo "error: kubectl has no current context."; \
		echo "Set KUBECONFIG or run 'kubectl config use-context <name>' before cluster tests."; \
		echo "Without a context, kubectl falls back to localhost:8080, which is the Kubernetes API endpoint, not the MCP service."; \
		exit 2; \
	}
	@kubectl cluster-info >/dev/null 2>&1 || { \
		echo "error: kubectl cannot reach the current Kubernetes context."; \
		echo "Check KUBECONFIG, credentials, VPN/network access, and cluster availability."; \
		echo "A localhost:8080 refusal means kubectl is trying its default Kubernetes API endpoint."; \
		exit 2; \
	}

.PHONY: test-cluster
test-cluster: check-kube-context ## Run MCP tests against the in-cluster test sidecar (auto kubectl port-forward)
	@echo "Running MCP tests against in-cluster service $(HELM_SERVICE) in namespace $(HELM_NAMESPACE)..."
	python test/test-mcp.py \
		--no-auth \
		--port-forward \
		--namespace $(HELM_NAMESPACE) \
		--service $(HELM_SERVICE) \
		--local-port $(MCP_TEST_PORT) \
		--remote-port $(MCP_TEST_PORT)

.PHONY: test-cluster-integration
test-cluster-integration: check-kube-context ## Run mutating integration tests against the in-cluster test sidecar
	@echo "Running mutating MCP integration tests against in-cluster service $(HELM_SERVICE) in namespace $(HELM_NAMESPACE)..."
	python test/test-mcp.py \
		--no-auth \
		--include-integration \
		--port-forward \
		--namespace $(HELM_NAMESPACE) \
		--service $(HELM_SERVICE) \
		--local-port $(MCP_TEST_PORT) \
		--remote-port $(MCP_TEST_PORT)

.PHONY: dev-deps
dev-deps: ## Install test-only dependencies (coverage, httpx)
	pip install -r test/requirements.txt

.PHONY: dev-coverage
dev-coverage: ## Run the test suite under coverage and print a report
	python test/run-coverage.py

.PHONY: dev-coverage-html
dev-coverage-html: ## Run dev-coverage and also write coverage-html/index.html
	python test/run-coverage.py --html

#
# Kubernetes targets
#

.PHONY: k8s-logs
k8s-logs: ## Show logs from deployed pods
	@echo "Logs from $(HELM_RELEASE):"
	kubectl logs -n $(HELM_NAMESPACE) -l app.kubernetes.io/name=cnpg-mcp --tail=100 -f

.PHONY: k8s-pods
k8s-pods: ## Show deployed pods
	kubectl get pods -n $(HELM_NAMESPACE) -l app.kubernetes.io/name=cnpg-mcp

.PHONY: k8s-port-forward
k8s-port-forward: ## Port-forward to deployed service on $(MCP_PORT) (production endpoint)
	@echo "Port forwarding to $(HELM_SERVICE) service in namespace $(HELM_NAMESPACE)..."
	@echo "Access at: http://localhost:$(MCP_PORT)/mcp"
	kubectl port-forward -n $(HELM_NAMESPACE) svc/$(HELM_SERVICE) $(MCP_PORT):$(MCP_PORT)

.PHONY: k8s-port-forward-test
k8s-port-forward-test: ## Port-forward to test sidecar on $(MCP_TEST_PORT) (no-auth endpoint)
	@echo "Port forwarding to $(HELM_SERVICE) test sidecar in namespace $(HELM_NAMESPACE)..."
	@echo "Access at: http://localhost:$(MCP_TEST_PORT)/test"
	kubectl port-forward -n $(HELM_NAMESPACE) svc/$(HELM_SERVICE) $(MCP_TEST_PORT):$(MCP_TEST_PORT)

#
# Utility targets
#

.PHONY: clean
clean: ## Clean generated files
	@echo "Cleaning generated files..."
	rm -f make.env .coverage .coverage.*
	rm -rf coverage-html
	find . -type d -name __pycache__ -prune -exec rm -rf {} +
	@echo "✓ Cleaned"

.PHONY: help
help: ## Show this help message
	@echo "cnpg-mcp MCP Server - Makefile"
	@echo ""
	@echo "Usage: make [target]"
	@echo ""
	@echo "Testing:"
	@echo "  make test               # Start local test server, run MCP tests, then stop it"
	@echo "  make test-integration   # Run local mutating CloudNativePG integration tests"
	@echo "  make dev-run-test       # Run test server manually for debugging"
	@echo "  make dev-coverage       # Run tests with coverage report"
	@echo "  make dev-coverage-html  # Run tests and write coverage-html/index.html"
	@echo "  make test-cluster       # Run tests against the in-cluster test sidecar"
	@echo "  make test-cluster-integration # Run mutating tests against in-cluster test sidecar"
	@echo "  make check-kube-context # Verify kubectl context before cluster tests"
	@echo ""
	@echo "Development:"
	@echo "  make dev-run            # Run production server locally"
	@echo "  make dev-deps           # Install test-only dependencies"
	@echo ""
	@echo "Container Build:"
	@echo "  make build              # Build production container image"
	@echo "  make build-test         # Build test container image"
	@echo "  make build-all          # Build both images"
	@echo "  make push               # Push production image"
	@echo "  make push-test          # Push test image"
	@echo "  make push-all           # Push both images"
	@echo ""
	@echo "Helm Chart:"
	@echo "  make helm-lint          # Lint Helm chart"
	@echo "  make helm-template      # Render chart templates"
	@echo "  make helm-deps          # Update chart dependencies"
	@echo "  make helm-install       # Install or upgrade release"
	@echo "  make helm-upgrade       # Upgrade existing release"
	@echo "  make helm-uninstall     # Uninstall release"
	@echo "  make helm-status        # Show release status"
	@echo ""
	@echo "Configuration:"
	@echo "  make config             # Regenerate make.env from mcp-project.yaml"
	@echo ""
	@echo "Quick Start:"
	@echo "  1. make test            # Run local no-auth test lifecycle"
	@echo "  2. make build           # Build production container image"
